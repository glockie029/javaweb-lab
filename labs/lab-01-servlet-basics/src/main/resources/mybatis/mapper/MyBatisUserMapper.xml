<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.lab01.mapper.MyBatisUserMapper">

    <select id="selectByUsernameSafe" resultType="com.example.lab01.model.MyBatisUserRecord">
        select id, username, role
        from demo_users
        where username = #{username}
    </select>

    <select id="selectByUsernameVulnerable" resultType="com.example.lab01.model.MyBatisUserRecord">
        select id, username, role
        from demo_users
        where username = '${username}'
    </select>
</mapper>
