    <servlet-mapping>
        <servlet-name>vulnerableDownloadServlet</servlet-name>
        <url-pattern>/download-vuln</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>safeDownloadServlet</servlet-name>
        <servlet-class>com.example.lab01.servlet.SafeDownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>safeDownloadServlet</servlet-name>
        <url-pattern>/download-safe</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>vulnerableUploadServlet</servlet-name>
