        <servlet-name>vulnerableXssServlet</servlet-name>
        <servlet-class>com.example.lab01.servlet.VulnerableXssServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>vulnerableXssServlet</servlet-name>
        <url-pattern>/xss-vuln</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>safeXssServlet</servlet-name>
